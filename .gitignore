# ──────────────────────────────────────────
# Java / Maven (backend)
# ──────────────────────────────────────────
backend/target/
backend/*.jar
backend/*.war
backend/*.class
backend/.mvn/wrapper/maven-wrapper.jar
!backend/.mvn/wrapper/maven-wrapper.properties

# ──────────────────────────────────────────
# Node / Angular (frontend)
# ──────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.angular/
frontend/coverage/
frontend/*.js.map

# ──────────────────────────────────────────
# Terraform
# ──────────────────────────────────────────
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/*.tfvars
terraform/override.tf
terraform/override.tf.json

# ──────────────────────────────────────────
# Docker
# ──────────────────────────────────────────
.dockerignore

# ──────────────────────────────────────────
# Secrets & credentials — never commit these
# ──────────────────────────────────────────
*.env
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.jks
kubeconfig
**/secrets.yaml
**/secret.yaml

# ──────────────────────────────────────────
# AI / Claude Code
# ──────────────────────────────────────────
.claude/

# ──────────────────────────────────────────
# SonarQube scanner cache
# ──────────────────────────────────────────
.sonar/
.scannerwork/

# ──────────────────────────────────────────
# Logs
# ──────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ──────────────────────────────────────────
# IDE / OS
# ──────────────────────────────────────────
.idea/
*.iml
.vscode/
.DS_Store
Thumbs.db
*.swp
*.swo

# ──────────────────────────────────────────
# Test & coverage reports
# ──────────────────────────────────────────
backend/src/test/resources/surefire-reports/
backend/target/site/
frontend/coverage/
